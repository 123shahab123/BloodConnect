{
  "name": "bloodconnect/api",
  "description": "BloodConnect — Laravel 11 REST API for Afghanistan",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0",
    "tymon/jwt-auth": "^2.1",
    "laravel/tinker": "^2.9"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "laravel/pint": "^1.13"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-install-cmd": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "audit": {
    "abandoned": "ignore",
    "ignore": [
      "PKSA-mdq4-51ck-6kdq",
      "PKSA-8qx3-n5y5-vvnd",
      "PKSA-q46n-4fdk-zjr4",
      "PKSA-qzrn-rnz3-85w1",
      "PKSA-w7xr-vk7n-rstm"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
