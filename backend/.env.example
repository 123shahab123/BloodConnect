APP_NAME=BloodConnect
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bloodconnect
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

JWT_SECRET=
JWT_TTL=20160
JWT_REFRESH_TTL=43200
JWT_ALGO=HS256

# Allow your React dev server - change port if different
FRONTEND_URL=http://localhost:3000

# FCM (optional - app works without this)
# FCM_CREDENTIALS_FILE=storage/app/firebase-credentials.json
