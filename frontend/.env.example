# ── API ──────────────────────────────────────────────────────────────────────
# Base URL of the Laravel backend API. Defaults to http://localhost:8000/api
# if unset, so this is optional for local dev.
VITE_API_URL=http://localhost:8000/api

# ── Firebase Cloud Messaging (Web Push) ─────────────────────────────────────
# Required for push notifications to work. These are PUBLIC identifiers
# (not secrets) — safe to ship in the client bundle. They are DIFFERENT
# from the backend's storage/app/firebase-credentials.json service account,
# which IS secret and must never be used here.
#
# How to get them — all free, no billing required:
#
#   1. Web app config (apiKey, authDomain, projectId, storageBucket,
#      messagingSenderId, appId):
#      Firebase Console → ⚙️ Project Settings → General tab → scroll to
#      "Your apps" → if you don't have a Web app yet, click the </> icon to
#      create one (don't enable Firebase Hosting, it's not needed) → copy
#      the `firebaseConfig` object shown.
#
#   2. VAPID key:
#      Firebase Console → ⚙️ Project Settings → Cloud Messaging tab →
#      scroll to "Web configuration" → "Web Push certificates" →
#      click "Generate key pair" → copy the resulting key string.
#
# Make sure all values below come from the SAME Firebase project as your
# backend's storage/app/firebase-credentials.json (matching project_id).

# Pre-filled below from your existing service-account project_id
# (bloodconnect-c005a) — double check authDomain/storageBucket against the
# Console copy, since newer Firebase projects (created after Oct 2024) use
# a "*.firebasestorage.app" bucket suffix instead of "*.appspot.com".
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=bloodconnect-c005a.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=bloodconnect-c005a
VITE_FIREBASE_STORAGE_BUCKET=bloodconnect-c005a.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
